# ─────────────────────────────────────────────────────────
# Retail Vision Intelligence System — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────
# Copie este ficheiro para .env e preencha os valores
# NUNCA faça commit do ficheiro .env nem do Apikey.txt
# ─────────────────────────────────────────────────────────

# Chave de API do Google Gemini (obrigatório)
# Obtenha gratuitamente em: https://aistudio.google.com
GEMINI_API_KEY=a_sua_chave_aqui

# Modelo Gemini a utilizar (por defeito: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Número máximo de resultados RAG (por defeito: 3)
# RAG_TOP_K=3

# Nível de log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=WARNING
